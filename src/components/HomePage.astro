---
import { readdirSync } from 'node:fs';
import { join } from 'node:path';
import CookieBanner from './CookieBanner.astro';

const {
  content,
  whatsappUrl,
  emailUrl,
  bookingUrl,
  airbnbUrl,
  googleMapsUrl
} = Astro.props;

const nav = content.nav;
const hero = content.hero;
const why = content.why;
const accommodations = content.accommodations;
const position = content.position;
const locationSection = content.location;
const amenities = content.amenities;
const contacts = content.contacts;
const footer = content.footer;

const currentPath = Astro.url.pathname;

const currentLang =
  currentPath.startsWith('/en')
    ? 'en'
    : currentPath.startsWith('/de')
      ? 'de'
      : 'it';

const imageExtensions = ['.avif', '.jpg', '.jpeg', '.png', '.webp'];
const publicImagesPath = join(process.cwd(), 'public', 'images');

const readGalleryFolder = (folderName) => {
  try {
    return readdirSync(join(publicImagesPath, folderName), { withFileTypes: true })
      .filter((file) => {
        const lowerName = file.name.toLowerCase();
        return file.isFile() && imageExtensions.some((extension) => lowerName.endsWith(extension));
      })
      .map((file) => file.name)
      .sort((first, second) =>
        first.localeCompare(second, undefined, { numeric: true, sensitivity: 'base' })
      )
      .map((fileName) => `/images/${folderName}/${fileName}`);
  } catch {
    return [];
  }
};

const accommodationGalleries = {
  apartment: readGalleryFolder('appartamento-primo-piano'),
  suite: readGalleryFolder('suite-panoramica'),
  complete: readGalleryFolder('soluzione-completa')
};

const mainGalleryImages = {
  apartment: '/images/appartamento-primo-piano/0017.png',
  suite: '/images/suite-panoramica/0068.png',
  complete: '/images/soluzione-completa/0001.png'
};

const placeMainImageFirst = (images, mainImage) => {
  if (!mainImage || !images.some((image) => image === mainImage)) {
    return images;
  }

  return [mainImage, ...images.filter((image) => image !== mainImage)];
};

const getAccommodationImages = (unit) =>
  placeMainImageFirst(
    accommodationGalleries[unit.galleryKey] ?? unit.images ?? [],
    mainGalleryImages[unit.galleryKey]
  ).map((image, index) =>
    typeof image === 'string'
      ? {
          src: image,
          alt: `${unit.title} - foto ${index + 1}`
        }
      : image
  );

const prepareAccommodationGallery = (unit) => {
  const images = getAccommodationImages(unit);

  return {
    ...unit,
    galleryImages: images,
    galleryMain: images[0]
  };
};

const accommodationUnits = accommodations.units.map(prepareAccommodationGallery);
---

<main class="page">
  <header class="site-header">
    <a class="site-logo" href="/">Villa Gusmano</a>

    <nav class="site-nav" aria-label="Main navigation">
      <a href="#perche-scegliere">{nav.why}</a>
      <a href="#alloggi">{nav.accommodations}</a>
      <a href="#posizione">{nav.position}</a>

      <a class="site-nav__contact" href="#contatti">{nav.contacts}</a>

      <a
        class="site-nav__location"
        href="#dove-siamo"
        aria-label={nav.location}
        title={nav.location}
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M12 21s7-6.4 7-12a7 7 0 1 0-14 0c0 5.6 7 12 7 12Z"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <circle
            cx="12"
            cy="9"
            r="2.4"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
          />
        </svg>
      </a>

      <details class="language-switcher">
        <summary class="language-switcher__current" aria-label="Change language">
          {currentLang === 'it' && '🇮🇹'}
          {currentLang === 'en' && '🇬🇧'}
          {currentLang === 'de' && '🇩🇪'}
        </summary>

        <div class="language-switcher__menu">
          <a href="/it/" aria-label="Italiano">🇮🇹</a>
          <a href="/en/" aria-label="English">🇬🇧</a>
          <a href="/de/" aria-label="Deutsch">🇩🇪</a>
        </div>
      </details>
    </nav>
  </header>

  <section class="hero">
    <div class="hero__content">
      <p class="eyebrow">{hero.eyebrow}</p>

      <h1>{hero.title}</h1>

      <p class="hero__text">
        {hero.subtitle}
      </p>

      <div class="hero__actions">
        <a
          class="button button--primary"
          href={whatsappUrl}
          target="_blank"
          rel="noopener"
          data-analytics-event="click_whatsapp"
          data-analytics-location="hero"
        >
          <span class="button__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path
                d="M20.5 11.8a8.4 8.4 0 0 1-12.4 7.4L3.5 20.5l1.3-4.5a8.4 8.4 0 1 1 15.7-4.2Z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.9"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              <path
                d="M8.9 8.4c.2-.4.4-.4.7-.4h.5c.2 0 .4 0 .5.4l.7 1.7c.1.3.1.5-.1.7l-.4.5c-.1.1-.2.3 0 .5.4.8 1.2 1.6 2.1 2.1.2.1.4.1.5 0l.6-.5c.2-.2.4-.2.7-.1l1.6.7c.4.2.4.3.4.6v.5c0 .3-.1.5-.4.7-.5.4-1.3.6-2 .5-2.8-.4-5.8-3.2-6.4-6-.1-.8.1-1.6.5-2.1Z"
                fill="currentColor"
              />
            </svg>
          </span>
          {hero.whatsappCta}
        </a>

        <a
          class="button button--secondary"
          href={emailUrl}
          data-analytics-event="click_email"
          data-analytics-location="hero"
        >
          <span class="button__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path
                d="M4 6h16v12H4V6Z"
                fill="none"
                stroke="currentColor"
                stroke-width="1.9"
                stroke-linejoin="round"
              />
              <path
                d="m4 7 8 6 8-6"
                fill="none"
                stroke="currentColor"
                stroke-width="1.9"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          {hero.emailCta}
        </a>
      </div>
    </div>
  </section>

  <section id="perche-scegliere" class="section">
    <p class="section__label">{why.label}</p>
    <h2>{why.title}</h2>

    <div class="features">
      {why.cards.map((card) => (
        <article class="card">
          <h3>{card.title}</h3>
          <p>{card.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="alloggi" class="section section--soft">
    <p class="section__label">{accommodations.label}</p>
    <h2>{accommodations.title}</h2>

    <div class="accommodation-list">
      {accommodationUnits.map((unit) => (
        <article class="accommodation">
          <div class="unit">
            <p class="unit__tag">{unit.tag}</p>
            <h3>{unit.title}</h3>

            <ul class="unit__list">
              {unit.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>

            <p class="unit__ideal">{unit.ideal}</p>
          </div>

          {unit.galleryImages.length > 0 && (
            <div class="unit-gallery" aria-label={unit.galleryLabel} data-gallery tabindex="0">
              <button
                class="unit-gallery__main"
                type="button"
                data-gallery-main-button
                data-full-src={unit.galleryMain.src}
                data-full-alt={unit.galleryMain.alt}
                data-gallery-index="0"
                aria-label={unit.galleryMain.alt}
              >
                <img
                  src={unit.galleryMain.src}
                  alt={unit.galleryMain.alt}
                  loading="lazy"
                  decoding="async"
                  data-gallery-main-image
                />

                <span class="unit-gallery__open-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path
                      d="M15 3h6v6m0-6-7 7M9 21H3v-6m0 6 7-7"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.1"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </button>

              <div class="unit-gallery__thumbs">
                {unit.galleryImages.map((image, index) => (
                  <button
                    class:list={['unit-gallery__thumb', { 'is-active': index === 0 }]}
                    type="button"
                    data-gallery-thumb
                    data-full-src={image.src}
                    data-full-alt={image.alt}
                    data-gallery-index={index}
                    aria-label={`${unit.title} - foto ${index + 1}`}
                  >
                    <img src={image.src} alt="" loading="lazy" decoding="async" />
                  </button>
                ))}
              </div>
            </div>
          )}
        </article>
      ))}
    </div>
  </section>

  <section id="posizione" class="section location-section">
    <p class="section__label">{position.label}</p>
    <h2>{position.title}</h2>

    <p class="location-section__intro">{position.intro}</p>

    <div class="location-grid">
      {position.cards.map((card) => (
        <article
          class:list={['location-card', { 'location-card--image': card.image }]}
          style={card.image ? `--location-image: url("${card.image}")` : undefined}
        >
          <strong>{card.title}</strong>
          <span>{card.time}</span>

          {card.note && <small>{card.note}</small>}

          {card.items && (
            <ul>
              {card.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>

    <section class="local-details">
      <div class="wineries-box">
        <h3>{position.wineries.title}</h3>
        <p class="wineries-box__intro">{position.wineries.intro}</p>

        <div class="wineries-list">
          {position.wineries.items.map((winery) => (
            <article class="winery">
              <strong>{winery.name}</strong>
              <p>{winery.text}</p>
            </article>
          ))}
        </div>
      </div>

      <aside class="nearby-box">
        <h3>{position.nearby.title}</h3>
        <p>{position.nearby.text}</p>
      </aside>
    </section>
  </section>

  <section id="dove-siamo" class="section map-section">
    <p class="section__label">{locationSection.label}</p>
    <h2>{locationSection.title}</h2>

    <p class="map-section__text">{locationSection.text}</p>

    <a
      class="button button--primary map-button"
      href={googleMapsUrl}
      target="_blank"
      rel="noopener"
      data-analytics-event="click_maps"
      data-analytics-location="location_section"
    >
      {locationSection.button}
    </a>
  </section>

  <section class="section amenities-section">
    <p class="section__label">{amenities.label}</p>
    <h2>{amenities.title}</h2>

    <div class="amenities-grid">
      {amenities.items.map((item) => (
        <article class="amenity-card">
          <span>{item}</span>
        </article>
      ))}
    </div>
  </section>

  <section id="contatti" class="section booking-section">
    <p class="section__label">{contacts.label}</p>
    <h2>{contacts.title}</h2>

    <p class="booking-section__text">{contacts.text}</p>

    <div class="booking-actions">
      <a
        class="button button--primary booking-button"
        href={whatsappUrl}
        target="_blank"
        rel="noopener"
        data-analytics-event="click_whatsapp"
        data-analytics-location="contacts"
      >
        <span class="button__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path
              d="M20.5 11.8a8.4 8.4 0 0 1-12.4 7.4L3.5 20.5l1.3-4.5a8.4 8.4 0 1 1 15.7-4.2Z"
              fill="none"
              stroke="currentColor"
              stroke-width="1.9"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <path
              d="M8.9 8.4c.2-.4.4-.4.7-.4h.5c.2 0 .4 0 .5.4l.7 1.7c.1.3.1.5-.1.7l-.4.5c-.1.1-.2.3 0 .5.4.8 1.2 1.6 2.1 2.1.2.1.4.1.5 0l.6-.5c.2-.2.4-.2.7-.1l1.6.7c.4.2.4.3.4.6v.5c0 .3-.1.5-.4.7-.5.4-1.3.6-2 .5-2.8-.4-5.8-3.2-6.4-6-.1-.8.1-1.6.5-2.1Z"
              fill="currentColor"
            />
          </svg>
        </span>
        {contacts.whatsapp}
      </a>

      <a
        class="button button--secondary booking-button"
        href={emailUrl}
        data-analytics-event="click_email"
        data-analytics-location="contacts"
      >
        <span class="button__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path
              d="M4 6h16v12H4V6Z"
              fill="none"
              stroke="currentColor"
              stroke-width="1.9"
              stroke-linejoin="round"
            />
            <path
              d="m4 7 8 6 8-6"
              fill="none"
              stroke="currentColor"
              stroke-width="1.9"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </span>
        {contacts.email}
      </a>

      <a
        class="button button--secondary booking-button"
        href={bookingUrl}
        target="_blank"
        rel="noopener"
        data-analytics-event="click_booking"
        data-analytics-location="contacts"
      >
        {contacts.booking}
      </a>

      <a
        class="button button--secondary booking-button"
        href={airbnbUrl}
        target="_blank"
        rel="noopener"
        data-analytics-event="click_airbnb"
        data-analytics-location="contacts"
      >
        {contacts.airbnb}
      </a>
    </div>
  </section>

  <footer class="site-footer">
    <div class="site-footer__content">
      <div class="site-footer__brand">
        <h3>Villa Gusmano</h3>
        <p>{footer.description}</p>
      </div>

      <div class="site-footer__links">
        <a href="#perche-scegliere">{nav.why}</a>
        <a href="#alloggi">{nav.accommodations}</a>
        <a href="#posizione">{nav.position}</a>
        <a href="#dove-siamo">{nav.location}</a>
        <a href="#contatti">{nav.contacts}</a>
      </div>

      <div class="site-footer__contacts">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener"
          data-analytics-event="click_whatsapp"
          data-analytics-location="footer"
        >
          {contacts.whatsapp}
        </a>

        <a
          href={bookingUrl}
          target="_blank"
          rel="noopener"
          data-analytics-event="click_booking"
          data-analytics-location="footer"
        >
          {contacts.booking}
        </a>

        <a
          href={airbnbUrl}
          target="_blank"
          rel="noopener"
          data-analytics-event="click_airbnb"
          data-analytics-location="footer"
        >
          {contacts.airbnb}
        </a>

        <a href="/privacy/">
          Privacy Policy
        </a>

        <a href="/cookie-policy/">
          Cookie Policy
        </a>
      </div>
    </div>

    <div class="site-footer__bottom">
      {footer.rights}
    </div>
  </footer>

  <dialog class="photo-dialog" data-photo-dialog>
    <button class="photo-dialog__close" type="button" data-photo-dialog-close aria-label="Chiudi foto">
      ×
    </button>

    <button class="photo-dialog__nav photo-dialog__nav--prev" type="button" data-photo-dialog-prev aria-label="Foto precedente">
      ‹
    </button>

    <img class="photo-dialog__image" src="" alt="" data-photo-dialog-image />

    <button class="photo-dialog__nav photo-dialog__nav--next" type="button" data-photo-dialog-next aria-label="Foto successiva">
      ›
    </button>
  </dialog>

  <a
    class="floating-whatsapp"
    href={whatsappUrl}
    target="_blank"
    rel="noopener"
    aria-label={contacts.whatsapp}
    data-analytics-event="click_whatsapp"
    data-analytics-location="floating_button"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path
        d="M20.5 11.8a8.4 8.4 0 0 1-12.4 7.4L3.5 20.5l1.3-4.5a8.4 8.4 0 1 1 15.7-4.2Z"
        fill="none"
        stroke="currentColor"
        stroke-width="1.9"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <path
        d="M8.9 8.4c.2-.4.4-.4.7-.4h.5c.2 0 .4 0 .5.4l.7 1.7c.1.3.1.5-.1.7l-.4.5c-.1.1-.2.3 0 .5.4.8 1.2 1.6 2.1 2.1.2.1.4.1.5 0l.6-.5c.2-.2.4-.2.7-.1l1.6.7c.4.2.4.3.4.6v.5c0 .3-.1.5-.4.7-.5.4-1.3.6-2 .5-2.8-.4-5.8-3.2-6.4-6-.1-.8.1-1.6.5-2.1Z"
        fill="currentColor"
      />
    </svg>
  </a>

  <CookieBanner />
</main>

<script>
  const galleries = document.querySelectorAll('[data-gallery]');
  const photoDialog = document.querySelector('[data-photo-dialog]');
  const photoDialogImage = document.querySelector('[data-photo-dialog-image]');
  const photoDialogClose = document.querySelector('[data-photo-dialog-close]');
  const photoDialogPrev = document.querySelector('[data-photo-dialog-prev]');
  const photoDialogNext = document.querySelector('[data-photo-dialog-next]');
  const analyticsLinks = document.querySelectorAll('[data-analytics-event]');
  let activeDialogImages = [];
  let activeDialogIndex = 0;
  let activeGalleryMainButton = null;
  let activeGalleryMainImage = null;
  let activeGalleryThumbs = [];

  const trackAnalyticsClick = (link) => {
    const analyticsConsent = localStorage.getItem('villa-cookie-consent');

    if (analyticsConsent !== 'accepted' || typeof window.gtag !== 'function') {
      return;
    }

    window.gtag('event', link.dataset.analyticsEvent, {
      link_text: link.textContent?.trim() || link.getAttribute('aria-label') || '',
      link_url: link.href,
      link_location: link.dataset.analyticsLocation || '',
      transport_type: 'beacon'
    });
  };

  analyticsLinks.forEach((link) => {
    link.addEventListener('click', () => {
      trackAnalyticsClick(link);
    });
  });

  const showDialogImage = (index) => {
    if (!photoDialogImage || activeDialogImages.length === 0) {
      return;
    }

    activeDialogIndex = (index + activeDialogImages.length) % activeDialogImages.length;
    const image = activeDialogImages[activeDialogIndex];

    photoDialogImage.setAttribute('src', image.src);
    photoDialogImage.setAttribute('alt', image.alt);

    if (activeGalleryMainImage && activeGalleryMainButton) {
      activeGalleryMainImage.setAttribute('src', image.src);
      activeGalleryMainImage.setAttribute('alt', image.alt);
      activeGalleryMainButton.setAttribute('data-full-src', image.src);
      activeGalleryMainButton.setAttribute('data-full-alt', image.alt);
      activeGalleryMainButton.setAttribute('data-gallery-index', String(activeDialogIndex));
      activeGalleryMainButton.setAttribute('aria-label', image.alt);
    }

    activeGalleryThumbs.forEach((thumb) => {
      const thumbIndex = Number(thumb.getAttribute('data-gallery-index') || '0');
      thumb.classList.toggle('is-active', thumbIndex === activeDialogIndex);
    });
  };

  galleries.forEach((gallery) => {
    const mainButton = gallery.querySelector('[data-gallery-main-button]');
    const mainImage = gallery.querySelector('[data-gallery-main-image]');
    const thumbs = Array.from(gallery.querySelectorAll('[data-gallery-thumb]'));
    const galleryImages = thumbs.map((thumb) => ({
      src: thumb.getAttribute('data-full-src') || '',
      alt: thumb.getAttribute('data-full-alt') || ''
    }));

    const showGalleryImage = (index) => {
      if (!mainImage || !mainButton || galleryImages.length === 0) {
        return;
      }

      const nextIndex = (index + galleryImages.length) % galleryImages.length;
      const image = galleryImages[nextIndex];

      mainImage.setAttribute('src', image.src);
      mainImage.setAttribute('alt', image.alt);
      mainButton.setAttribute('data-full-src', image.src);
      mainButton.setAttribute('data-full-alt', image.alt);
      mainButton.setAttribute('data-gallery-index', String(nextIndex));
      mainButton.setAttribute('aria-label', image.alt);

      thumbs.forEach((item) => {
        const thumbIndex = Number(item.getAttribute('data-gallery-index') || '0');
        item.classList.toggle('is-active', thumbIndex === nextIndex);
      });
    };

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const nextIndex = Number(thumb.getAttribute('data-gallery-index') || '0');
        showGalleryImage(nextIndex);
      });
    });

    gallery.addEventListener('keydown', (event) => {
      if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') {
        return;
      }

      if (photoDialog instanceof HTMLDialogElement && photoDialog.open) {
        return;
      }

      event.preventDefault();

      const currentIndex = Number(mainButton?.getAttribute('data-gallery-index') || '0');
      showGalleryImage(event.key === 'ArrowLeft' ? currentIndex - 1 : currentIndex + 1);
    });

    mainButton?.addEventListener('click', () => {
      const currentIndex = Number(mainButton.getAttribute('data-gallery-index') || '0');

      if (!(photoDialog instanceof HTMLDialogElement) || !photoDialogImage) {
        return;
      }

      activeDialogImages = galleryImages;
      activeGalleryMainButton = mainButton;
      activeGalleryMainImage = mainImage;
      activeGalleryThumbs = thumbs;
      showDialogImage(currentIndex);
      photoDialog.showModal();
    });
  });

  photoDialogClose?.addEventListener('click', () => {
    if (photoDialog instanceof HTMLDialogElement) {
      photoDialog.close();
    }
  });

  photoDialog?.addEventListener('click', (event) => {
    if (event.target === photoDialog && photoDialog instanceof HTMLDialogElement) {
      photoDialog.close();
    }
  });

  photoDialogPrev?.addEventListener('click', () => {
    showDialogImage(activeDialogIndex - 1);
  });

  photoDialogNext?.addEventListener('click', () => {
    showDialogImage(activeDialogIndex + 1);
  });

  document.addEventListener('keydown', (event) => {
    if (!(photoDialog instanceof HTMLDialogElement) || !photoDialog.open) {
      return;
    }

    if (event.key === 'ArrowLeft') {
      showDialogImage(activeDialogIndex - 1);
    }

    if (event.key === 'ArrowRight') {
      showDialogImage(activeDialogIndex + 1);
    }
  });
</script>

<style>
  @font-face {
    font-family: "Great Vibes";
    src: url("/fonts/great-vibes.ttf") format("truetype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --color-green: #516b48;
    --color-green-dark: #263424;
    --color-sand: #f4efe6;
    --color-white: #ffffff;
    --color-text: #1f261f;
    --color-muted: #657064;
    --shadow-card: 0 18px 50px rgba(38, 52, 36, 0.12);
    --radius-medium: 20px;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
